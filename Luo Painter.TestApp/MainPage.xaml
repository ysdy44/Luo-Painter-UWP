                                    <FontIcon Canvas.Left="52" Canvas.Top="28" Glyph="&#xEF3C;" FontSize="24" FontFamily="Segoe MDL2 Assets" Foreground="DeepSkyBlue"/>
                                </Canvas>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" VerticalAlignment="Center">
                                    Eyedropper
                                </TextBlock>
                            </StackPanel>
