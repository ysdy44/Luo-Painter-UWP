                        <Button Width="156" Height="134" BorderThickness="0" BorderBrush="Transparent" Background="Transparent" Command="{x:Bind Command}">
                            <ButtonBase.CommandParameter>
                                Number
                            </ButtonBase.CommandParameter>
                            <StackPanel>
                                <Canvas IsHitTestVisible="False" Width="128" Height="82" Background="#D2D2D2">
                                    <Rectangle Canvas.Left="32" Canvas.Top="28" RadiusX="4" RadiusY="4" Width="64" Height="24" Fill="DeepSkyBlue"/>
                                    <Ellipse Canvas.Left="58" Canvas.Top="31" Width="12" Height="18" StrokeThickness="2" Stroke="White"/>
                                </Canvas>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" VerticalAlignment="Center">
                                    Number
                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <Button Width="156" Height="134" BorderThickness="0" BorderBrush="Transparent" Background="Transparent" Command="{x:Bind Command}">
                            <ButtonBase.CommandParameter>
                                SliderToolTip
                            </ButtonBase.CommandParameter>
                            <StackPanel>
                                <Canvas IsHitTestVisible="False" Width="128" Height="82" Background="#D2D2D2">
                                    <Rectangle Canvas.Left="32" Canvas.Top="8" RadiusX="4" RadiusY="4" Width="64" Height="64" Fill="DeepSkyBlue"/>
