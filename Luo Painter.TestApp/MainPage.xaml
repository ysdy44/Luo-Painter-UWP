                                </Canvas>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" VerticalAlignment="Center">
                                    Canvas Transformer 2
                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <Button Width="156" Height="134" BorderThickness="0" BorderBrush="Transparent" Background="Transparent" Command="{x:Bind Command}">
                            <ButtonBase.CommandParameter>
                                CanvasTransformer3
                            </ButtonBase.CommandParameter>
                            <StackPanel>
                                <Canvas IsHitTestVisible="False" Width="128" Height="82" Background="#D2D2D2">
                                    <Rectangle Canvas.Left="20" Canvas.Top="10" Width="88" Height="62" Fill="#F3F3F3"/>
                                    <Rectangle Canvas.Left="42" Canvas.Top="18" Width="44" Height="44" StrokeThickness="2" Stroke="DeepSkyBlue" Fill="White"/>

                                    <Rectangle Canvas.Left="40" Canvas.Top="16" Width="6" Height="6" Fill="DeepSkyBlue"/>
