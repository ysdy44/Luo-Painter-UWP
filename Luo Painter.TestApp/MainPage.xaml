                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <Button Width="156" Height="134" BorderThickness="0" BorderBrush="Transparent" Background="Transparent" Command="{x:Bind Command}">
                            <ButtonBase.CommandParameter>
                                NightSkyTimeLapse
                            </ButtonBase.CommandParameter>
                            <StackPanel>
                                <Canvas IsHitTestVisible="False" Width="128" Height="82" Background="DeepSkyBlue">
                                    <Path StrokeThickness="1" Stroke="White">
                                        <Path.Data>
                                            <PathGeometry>
                                                <PathGeometry.Figures>
                                                    <PathFigureCollection>
                                                        <PathFigure StartPoint="12,74">
                                                            <PathFigure.Segments>
                                                                <ArcSegment Size="54,54" Point="116,74" IsLargeArc="True" SweepDirection="Clockwise"/>
                                                            </PathFigure.Segments>
                                                        </PathFigure>
                                                        <PathFigure StartPoint="24,74">
                                                            <PathFigure.Segments>
                                                                <ArcSegment Size="42,42" Point="104,74" IsLargeArc="True" SweepDirection="Clockwise"/>
                                                            </PathFigure.Segments>
                                                        </PathFigure>
                                                        <PathFigure StartPoint="34,74">
                                                            <PathFigure.Segments>
                                                                <ArcSegment Size="32,32" Point="94,74" IsLargeArc="True" SweepDirection="Clockwise"/>
                                                            </PathFigure.Segments>
                                                        </PathFigure>
                                                    </PathFigureCollection>
                                                </PathGeometry.Figures>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                </Canvas>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" VerticalAlignment="Center">
                                    Night Sky Time Lapse
                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <Button Width="156" Height="134" BorderThickness="0" BorderBrush="Transparent" Background="Transparent" Command="{x:Bind Command}">
                            <ButtonBase.CommandParameter>
                                SpottedPattern
                            </ButtonBase.CommandParameter>
                            <StackPanel>
                                <Canvas IsHitTestVisible="False" Width="128" Height="82" Background="DeepSkyBlue">
                                    <Line X1="22" Y1="2" X2="2" Y2="52" StrokeThickness="2" StrokeDashArray="1 8" Stroke="White"/>
                                    <Line X1="42" Y1="2" X2="6" Y2="82" StrokeThickness="2" StrokeDashArray="1 8" Stroke="White"/>
                                    <Line X1="62" Y1="2" X2="26" Y2="82" StrokeThickness="3" StrokeDashArray="1 6" Stroke="White"/>
                                    <Line X1="82" Y1="2" X2="46" Y2="82" StrokeThickness="3" StrokeDashArray="1 6" Stroke="White"/>
                                    <Line X1="102" Y1="2" X2="66" Y2="82" StrokeThickness="4" StrokeDashArray="1 4" Stroke="White"/>
                                    <Line X1="122" Y1="2" X2="86" Y2="82" StrokeThickness="4" StrokeDashArray="1 4" Stroke="White"/>
                                    <Line X1="124" Y1="38" X2="106" Y2="82" StrokeThickness="5" StrokeDashArray="1 3" Stroke="White"/>
                                </Canvas>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" VerticalAlignment="Center">
                                    Spotted Pattern
                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <Button Width="156" Height="134" BorderThickness="0" BorderBrush="Transparent" Background="Transparent" Command="{x:Bind Command}">
                            <ButtonBase.CommandParameter>
                                SolarSystem
                            </ButtonBase.CommandParameter>
                            <StackPanel>
                                <Canvas IsHitTestVisible="False" Width="128" Height="82" Background="DeepSkyBlue">
                                    <Ellipse Canvas.Left="22" Canvas.Top="25" Width="32" Height="32" Fill="#7ADEFF"/>
                                    <Ellipse Canvas.Left="62" Canvas.Top="30" Width="22" Height="22" Fill="#B8EDFF"/>
                                    <Ellipse Canvas.Left="92" Canvas.Top="35" Width="12" Height="12" Fill="White"/>
                                </Canvas>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" VerticalAlignment="Center">
                                    Solar System
                                </TextBlock>
                            </StackPanel>
                        </Button>

                    </VariableSizedWrapGrid>

                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Visibility="Collapsed" MinHeight="178" MaxHeight="338" VerticalAlignment="Top" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                <FrameworkElement.Tag>
                    Input
                </FrameworkElement.Tag>
                <StackPanel Margin="8">

                    <TextBlock Margin="14,4" Transitions="{StaticResource Entrance}">
                        General
                    </TextBlock>

                    <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="156" ItemHeight="134" ChildrenTransitions="{StaticResource Entrance}">

                        <Button Width="156" Height="134" BorderThickness="0" BorderBrush="Transparent" Background="Transparent" Command="{x:Bind Command}">
                            <ButtonBase.CommandParameter>
                                TextLayouts
                            </ButtonBase.CommandParameter>
                            <StackPanel>
                                <Canvas IsHitTestVisible="False" Width="128" Height="82" Background="#D2D2D2">
                                    <TextBlock Canvas.Left="42" FontSize="64" Foreground="DeepSkyBlue">
                                        A
                                    </TextBlock>
                                </Canvas>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" VerticalAlignment="Center">
                                    Text Layouts
                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <Button Width="156" Height="134" BorderThickness="0" BorderBrush="Transparent" Background="Transparent" Command="{x:Bind Command}">
                            <ButtonBase.CommandParameter>
                                CustomEditor
                            </ButtonBase.CommandParameter>
                            <StackPanel>
                                <Canvas IsHitTestVisible="False" Width="128" Height="82" Background="#D2D2D2">
                                    <TextBlock Canvas.Left="14" FontSize="64" Foreground="DeepSkyBlue">
                                        abc
                                    </TextBlock>
                                </Canvas>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" VerticalAlignment="Center">
                                    Custom Editor
                                </TextBlock>
                            </StackPanel>
                        </Button>

                    </VariableSizedWrapGrid>

                    <TextBlock Margin="14,4" Transitions="{StaticResource Entrance}">
                        Thumb
                    </TextBlock>

                    <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="156" ItemHeight="134" ChildrenTransitions="{StaticResource Entrance}">

                        <Button Width="156" Height="134" BorderThickness="0" BorderBrush="Transparent" Background="Transparent" Command="{x:Bind Command}">
